---
import Base from "../layouts/Base.astro";
---
<Base title="QDN — Idea to market, faster | qdn.vn" description="QDN is a product & AI studio that takes your idea to market faster — a clickable AI mockup in a day, then a premium web, mobile or SaaS product shipped in weeks.">
<!-- HERO -->
<section class="hero"><div class="wrap hero-grid"><div>
<div class="spec-lab"><span class="b">QDN</span> · PRODUCT &amp; AI STUDIO · qdn.vn</div>
<h1>Idea to market,<br><span class="it">faster</span>.</h1>
<p class="lead">QDN builds web, mobile and SaaS products. We use AI to turn your idea into a working mockup in a day — then ship fast to market.</p>
<div class="hero-cta"><a href="/contact" class="btn btn-ink">Start a project <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a><a href="#how" class="btn btn-line">How we work</a></div>
<div class="hero-meta"><div><div class="mono">Mockup</div><div class="n">in a day</div></div><div><div class="mono">Faster delivery</div><div class="n">2×</div></div><div><div class="mono">Shipped</div><div class="n">50+</div></div></div>
</div>
<div class="specimen" id="specimen"><div class="flow"><span class="stp s-idea"><i class="d"></i>Idea</span><span class="seg"><i></i></span><span class="stp s-mockup"><i class="d"></i>AI mockup</span><span class="seg"><i></i></span><span class="stp s-live"><i class="d"></i>Live</span><span class="flow-day">idea &rarr; live</span></div><div class="card"><span class="sheen"></span><div class="bar"><i></i><i></i><i></i><span class="u">app.qdn.vn / <b class="u-state">mockup</b></span><span class="live-dot"></span><div class="spec-toggle"><button class="on" data-m="mockup">Mockup</button><button data-m="live">Live</button></div></div><div class="prompt"><span class="pc">&rsaquo;</span> <span class="pt">build an AI travel planner</span><span class="caret"></span></div><div class="app"><aside class="side"><span class="brandmk"></span><span class="nav on"></span><span class="nav"></span><span class="nav"></span><span class="nav"></span></aside><div class="main"><div class="apptop"><span class="ln"></span><span class="cta-btn">New trip</span></div><div class="chat"><div class="msg in"><span class="ava"></span><span class="bub"><span class="ln l"></span><span class="ln s"></span></span></div><div class="msg out"><span class="bub bot"><span class="ln l"></span></span><span class="ava bot"></span></div><div class="typing"><span></span><span></span><span></span></div></div><div class="rows"><div class="rw"><span class="av"></span><span class="ln l"></span><span class="pill"></span></div><div class="rw"><span class="av"></span><span class="ln l"></span><span class="pill"></span></div><div class="rw"><span class="av"></span><span class="ln l"></span><span class="pill"></span></div></div></div></div></div></div></div></section>

<!-- PROMISE -->
<section class="sec pb-0"><div class="wrap"><div class="shead ctr rv"><div class="spec-lab justify-center"><span class="b">—</span> the idea</div><h2 class="max-w-2xl mx-auto mt-3.5">See your product as a real mockup <span class="it">in a day</span> — and live, in weeks.</h2></div></div></section>

<!-- WHAT WE BUILD -->
<section class="sec"><div class="wrap"><div class="shead rv"><div class="spec-lab"><span class="b">—</span> what we build</div><h2>Apps and <span class="it">SaaS</span>, end to end</h2><p>From a first mockup to a launched product — we cover the whole build.</p></div>
<div class="proc">
<div class="pc rv"><div class="num">WEB</div><h3>Web &amp; SaaS</h3><p>SaaS platforms, dashboards, CRM and internal tools.</p></div>
<div class="pc rv"><div class="num">MOBILE</div><h3>Mobile apps</h3><p>iOS and Android — native and cross-platform.</p></div>
<div class="pc rv"><div class="num">AI</div><h3>AI solutions</h3><p>Agents, automation and AI-native features, in production.</p></div>
<div class="pc rv"><div class="num">PRODUCT</div><h3>SaaS products</h3><p>End-to-end: mockup, build, launch, scale.</p></div>
<div class="pc rv"><div class="num">AUTO</div><h3>Automation</h3><p>Workflows that remove the manual work.</p></div>
<div class="pc rv"><div class="num">COMMERCE</div><h3>E-commerce</h3><p>Shopify and custom commerce, wired to your data.</p></div>
</div>
<div class="rv mt-9"><a href="/services" class="btn btn-line">All services <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a></div></div></section>

