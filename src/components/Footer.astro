---
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const L = (p: string) => localizePath(p, lang);
---
<footer class="site">
  <div class="wrap">
    <div class="foot">
      <div>
        <a href={L('/')} class="logo">
          <svg class="logomark" viewBox="0 0 32 32" aria-hidden="true"><rect x="2.5" y="2.5" width="27" height="27" rx="7" fill="none" stroke="#1c1b18" stroke-width="2"/><rect x="11" y="11" width="10" height="10" rx="2.5" fill="#e2622a"/></svg>
          <span>QDN</span>
        </a>
        <p class="fd">{t.footer.tagline}</p>
      </div>
      <div>
        <h2>{t.footer.colBuild}</h2>
        <a href={L('/services')}>{t.footer.lBuild[0]}</a>
        <a href={L('/services')}>{t.footer.lBuild[1]}</a>
        <a href={L('/services')}>{t.footer.lBuild[2]}</a>
        <a href={L('/services')}>{t.footer.lBuild[3]}</a>
      </div>
      <div>
        <h2>{t.footer.colProducts}</h2>
        <a href={L('/products')}>{t.footer.lProducts[0]}</a>
        <a href={L('/products')}>{t.footer.lProducts[1]}</a>
        <a href={L('/products')}>{t.footer.lProducts[2]}</a>
      </div>
      <div>
        <h2>{t.footer.colStudio}</h2>
        <a href={L('/about')}>{t.footer.lStudioAbout}</a>
        <a href={L('/journal')}>{t.footer.lStudioJournal}</a>
        <a href={L('/contact')}>{t.footer.lStudioContact}</a>
      </div>
    </div>
    <div class="fbar"><span>{t.footer.copyright}</span><span>{t.footer.fbarRight}</span></div>
  </div>
</footer>
