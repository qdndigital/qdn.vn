---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { getLangFromUrl, alternates } from '../i18n/utils';

const { title, description, noindex = false } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const ogImage = new URL('/assets/og.png?v=2', Astro.site).href;
const ogAlt = lang === 'vi' ? 'QDN — Từ ý tưởng ra thị trường, nhanh hơn' : 'QDN — Idea to market, faster';

// hreflang alternates (and the matching og:locale tags)
const alt = alternates(Astro.url.pathname);
const enHref = new URL(alt.en, Astro.site).href;
const viHref = new URL(alt.vi, Astro.site).href;
// canonical = this page's own localized URL, identical to its hreflang entry
const canonical = lang === 'vi' ? viHref : enHref;
const ogLocale = lang === 'vi' ? 'vi_VN' : 'en_US';
const ogLocaleAlt = lang === 'vi' ? 'en_US' : 'vi_VN';

const jsonld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://qdn.vn/#org',
      name: 'QDN',
      url: 'https://qdn.vn/',
      email: 'quang.dinh@qdn.vn',
      description:
        'A product & AI studio building premium web, mobile and SaaS products. We use AI to turn an idea into a clickable mockup fast, then ship to market quickly.',
      logo: 'https://qdn.vn/favicon.svg',
      areaServed: 'Worldwide',
      knowsAbout: ['Web development', 'Mobile apps', 'AI solutions', 'SaaS', 'Automation', 'E-commerce'],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://qdn.vn/#website',
      url: 'https://qdn.vn/',
      name: 'QDN',
      publisher: { '@id': 'https://qdn.vn/#org' },
    },
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {/* Self-hosted fonts (see src/styles/fonts.css) — no third-party origin.
        Preload only the two faces visible above the fold; the rest load on demand. */}
    <link rel="preload" href="/fonts/inter-vf-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/jetbrainsmono-vf-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/instrumentserif-400i-latin.woff2" as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="vi" href={viHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#e9e7e2" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="QDN" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogAlt} />
    <link rel="sitemap" href="/sitemap.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <Footer />
    <script src="/assets/app.js" is:inline defer></script>
  </body>
</html>
